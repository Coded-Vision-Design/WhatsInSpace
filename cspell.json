{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell-types.schema.json",
  "version": "0.2",
  "language": "en-GB",
  "words": [
    "whatsthatin",
    "artemis",
    "tailwindcss",
    "postcss",
    "lucide",
    "fortawesome",
    "fontawesome",
    "drei",
    "hostinger",
    "pnpm",
    "nextjs",
    "favicon",
    "unoptimized",
    "tsbuildinfo",
    "autoprefixer",
    "ogl",
    "glb",
    "gltf",
    "webp",
    "ftps",
    "devcontainer",
    "lighthouserc",
    "cspell",
    "codedvisiondesign",
    "threejs",
    "fibre",
    "lychee"
  ],
  "ignorePaths": [
    "node_modules",
    ".next",
    "out",
    "pnpm-lock.yaml",
    "public/models",
    "public/textures",
    "public/nasa-iss-frames",
    "public/voyager-frames",
    "*.glb",
    "*.gltf",
    "*.json",
    ".github"
  ],
  "flagWords": [
    "color",
    "colors",
    "favor",
    "favorite",
    "honor",
    "humor",
    "labor",
    "neighbor",
    "optimize",
    "organize",
    "recognize",
    "customize",
    "analyze",
    "apologize",
    "authorize",
    "categorize",
    "centralize",
    "characterize",
    "civilization",
    "memorize",
    "minimize",
    "modernize",
    "neutralize",
    "normalize",
    "prioritize",
    "realize",
    "specialize",
    "summarize",
    "standardize",
    "synchronize",
    "utilize",
    "visualize"
  ],
  "overrides": [
    {
      "filename": "**/*.{ts,tsx}",
      "ignoreRegExpList": [
        "/(?:css|style|className|bg|text|border|fill|stroke|shadow|ring|outline|accent|caret|decoration|from|via|to)-\\w+/",
        "/['\"]#[0-9a-fA-F]{3,8}['\"]/",
        "/color[\"':\\s]/",
        "/(background|fill|stroke)Color/",
        "/\\bcolor\\b(?=\\s*[:=])/",
        "/color:\\s/",
        "/\\.color\\b/",
        "/THREE\\.Color/",
        "/new\\s+Color/"
      ]
    }
  ]
}
